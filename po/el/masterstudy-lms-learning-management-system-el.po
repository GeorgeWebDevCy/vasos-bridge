#: includes/Plugin/Addons.php:116
#: _core/settings/main_settings/ai_lab.php:10
#: _core/settings/main_settings/ai_lab.php:97
#: _core/settings/main_settings/ai_lab.php:103
#: _core/settings/main_settings/ai_lab.php:109
